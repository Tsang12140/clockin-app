{
  "appEnvPath": "/www/wwwroot/clockin-app/.env.local",
  "tmpDir": "/www/backup/tmp",
  "logDir": "/www/backup/logs",
  "s3": {
    "endpoint": "https://s3.bitiful.net",
    "region": "cn-east-1",
    "accessKeyId": "YOUR_ACCESS_KEY_ID",
    "secretAccessKey": "YOUR_SECRET_ACCESS_KEY",
    "bucket": "YOUR_BUCKET",
    "forcePathStyle": false
  },
  "retention": {
    "dailyDbDays": 365,
    "weeklyCodeVersions": 52
  }
}
